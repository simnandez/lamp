#!/bin/bash

# --- Definición de Colores ---
BG_AZUL='\033[44;37;1m'
BG_ROJO='\033[41;37;1m'
BG_AMARILLO='\033[43;30m'
VERDE='\033[1;32m'
CYAN='\033[1;36m'
BLANCO='\033[1;37m'
AZUL='\033[1;34m'
NC='\033[0m'
C_GRAY='\033[0;90m'

LOG_PATH="/home/tienda/logs/access_log"
# --- Configuración AbuseIPDB ---
API_KEY="44ca76e72d5756fe20c2fcf06b20167b5a25b29ab79db622534f8cfaa648fa23a7fd381b5ce5fb6c"

# --- FUNCIÓN: CONSULTA ABUSEIPDB (CON CACHÉ Y ALINEACIÓN) ---
check_abuse() {
    local ip=$1
    local cache_file="/tmp/abuse_cache_${ip}.txt"
    local now=$(date +%s)

    if [ -f "$cache_file" ]; then
        local cache_time=$(stat -c %Y "$cache_file")
        if (( now - cache_time < 3600 )); then
            cat "$cache_file"
            return
        fi
    fi

    local res=$(curl -s -G https://api.abuseipdb.com/api/v2/check \
      --data-urlencode "ipAddress=$ip" \
      -d maxAgeInDays=90 \
      -H "Key: $API_KEY" \
      -H "Accept: application/json")

    if echo "$res" | grep -q "errors"; then
        echo -e "${BG_ROJO} LIMIT ERR ${NC} | Desconocido" | tee "$cache_file"
        return
    fi

    local score=$(echo "$res" | jq -r '.data.abuseConfidenceScore' 2>/dev/null)
    local isp=$(echo "$res" | jq -r '.data.isp' 2>/dev/null | sed 's/null/Desconocido/' | cut -c1-12)

    local output=""
    if [[ "$score" == "null" || -z "$score" ]]; then
        output="${AZUL}S:--%${NC}|$isp"
    else
        local col_s=${VERDE}
        [ "$score" -gt 20 ] && col_s=${CYAN}
        [ "$score" -gt 50 ] && col_s=${BG_AMARILLO}
        [ "$score" -gt 80 ] && col_s=${BG_ROJO}

        # Eliminamos el printf "%3s" para que no añada espacios de relleno
        output="${col_s}S:${score}%${NC}|$isp"
    fi

    echo -e "$output" > "$cache_file"
    echo -e "$output"
}

# --- FUNCIÓN: INSPECCIONAR IP (FILTRADO VISUAL JS/IMG) ---
inspect_ip() {
    local target_ip=$1
    echo -e "\n${BG_AMARILLO}  >>> ANALIZANDO COMPORTAMIENTO: $target_ip  ${NC}"
    echo -e "${AZUL}Colores: ${C_GRAY}Gris=Estáticos${NC} | ${BLANCO}Blanco=Páginas/Scripts${NC}"
    echo "--------------------------------------------------------------------------------------------------------------------------------------------------------------------------"

    # ENCABEZADO: Ajustamos anchos (URL 50 y UA el resto)
    printf "${AZUL}%-15s | %-8s | %-5s | %-50s | %-3s | %s${NC}\n" "IP" "HORA" "MET." "URL" "COD" "USER-AGENT (Identidad)"
    echo "--------------------------------------------------------------------------------------------------------------------------------------------------------------------------"

    grep "$target_ip" "$LOG_PATH" | tail -n 100 | awk -F'"' '{
        split($1, p, " ");
        ip=p[1];
        match($1, /[0-9]{2}:[0-9]{2}:[0-9]{2}/); hora=substr($1, RSTART, RLENGTH);

        split($2, r, " ");
        metodo=r[1]; url=r[2];

        split($3, s, " ");
        codigo=s[1];

        ua=$6;

        # COLORES
        C_GRAY="\033[0;90m"; C_WHITE="\033[1;37m"; C_CYAN="\033[1;36m";
        C_NC="\033[0m"; C_RED="\033[1;31m"; C_GREEN="\033[1;32m"; C_YELLOW="\033[1;33m";

        # 1. DETECCIÓN DE BOT (Incluye Amazon, NetworkingExtension, etc.)
        es_bot = 0;
        if (tolower(ua) ~ /bot|crawler|spider|openai|chatgpt|bing|google|python|headless|networkingextension|amazon/) es_bot = 1;

        # 2. LIMPIEZA RADICAL (Por partes para que no falle)
        gsub(/Mozilla\/5.0/, "", ua);
        gsub(/AppleWebKit\/[0-9.]+/, "", ua);
        gsub(/KHTML, like Gecko/, "", ua);
        gsub(/compatible;/, "", ua);
        gsub(/Safari\/[0-9.]+/, "", ua);
        gsub(/Chrome\/[0-9.]+/, "Chrome", ua);
        gsub(/\( \)/, "", ua); # Limpia paréntesis vacíos que quedan tras borrar lo de dentro
        gsub(/^ +| +$/, "", ua); # Quita espacios al principio y final

        # 3. IDENTIFICACIÓN VISUAL
        if (es_bot) {
            tipo_ua = C_YELLOW "[BOT] " C_NC;
        } else {
            tipo_ua = C_CYAN "[USER] " C_NC;
        }

        # 4. COLORES DE FILA
        color_url=C_WHITE;
        if (url ~ /\.(jpg|jpeg|png|gif|css|js|ico|woff|svg)$/) color_url=C_GRAY;

        col_code=C_GREEN;
        if (codigo >= 400) col_code=C_RED;
        if (codigo >= 300 && codigo < 400) col_code=C_YELLOW;

        # 5. IMPRESIÓN: Reducimos URL a 50 para que el UA no salte de línea
        printf "%-15s | %-8s | %s%-5s%s | %s%-50.50s%s | %s%-3s%s | %s%.70s\n", \
            ip, hora, C_CYAN, metodo, C_NC, color_url, url, C_NC, col_code, codigo, C_NC, tipo_ua, ua
    }'

    echo "--------------------------------------------------------------------------------------------------------------------------------------------------------------------------"
    echo -e "${CYAN}Reputación:${NC} $(check_abuse $target_ip)"
    echo -e "${CYAN}Origen:${NC}      $(geoiplookup $target_ip 2>/dev/null | awk -F', ' '{print $2}')"
    echo -e "${AZUL}Total hoy:${NC}   $(grep -c "$target_ip" "$LOG_PATH") peticiones"
    echo -e "${AZUL}==========================================================================================================================================================================${NC}"
    read -p "Pulsa [Enter] para volver al monitor..."
}

# --- FUNCIÓN: BANEO RÁPIDO ---
ban_ip_manual() {
    echo -e "\n${BG_ROJO}  [!] MODO BANEO MANUAL ACTIVO  ${NC}"
    read -p " Introduce la IP a bloquear: " IP_B
    if [[ -z "$IP_B" ]]; then
        echo "Error: IP no válida."
    else
        echo -e "\n¿Qué tipo de bloqueo quieres aplicar?"
        echo -e " 1) Bloquear solo la IP: ${CYAN}$IP_B${NC}"
        echo -e " 2) Bloquear RANGO /16: ${CYAN}${IP_B%.*.*}.0.0/16${NC}"
        echo -e " 3) Cancelar"
        read -p " Selecciona opción [1-3]: " opt_b

        case $opt_b in
            1) sudo iptables -I INPUT -s "$IP_B" -j DROP; echo -e "${VERDE}[OK]${NC} IP bloqueada." ;;
            2) RANGO=$(echo $IP_B | cut -d'.' -f1-2).0.0/16; sudo iptables -I INPUT -s "$RANGO" -j DROP; echo -e "${VERDE}[OK]${NC} Rango bloqueado." ;;
            *) echo "Operación cancelada." ;;
        esac
    fi
    sleep 1
}

# --- FUNCIÓN: DESBANEO ---
unban_ip() {
    local IP_TO_UNBAN=$1
    echo -e "\n${BG_AMARILLO}  >>> DESBANEANDO: $IP_TO_UNBAN  ${NC}"
    JAILS=$(sudo fail2ban-client status | grep "Jail list" | sed "s/.*: \t//;s/,//g")
    for jail in $JAILS; do
        sudo fail2ban-client set $jail unbanip $IP_TO_UNBAN > /dev/null 2>&1
    done
    while sudo iptables -D INPUT -s $IP_TO_UNBAN -j DROP 2>/dev/null; do :; done
    echo -e "${VERDE}[OK]${NC} IP liberada."
    sleep 1
}

# --- MODO DESBANEO POR PARÁMETRO ---
if [ "$1" == "unban" ]; then
    unban_ip $2; exit 0
fi

# --- MENÚ DE INICIO ---
if [ -z "$1" ]; then
    clear
    echo -e "${AZUL}╔═════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${AZUL}║${NC}       ${BLANCO}SISTEMA DE CONTROL DE ACCESO - AIRSOFT GANDIA${NC}         ${AZUL}║${NC}"
    echo -e "${AZUL}╚═════════════════════════════════════════════════════════════╝${NC}"
    echo -e " 1) ${CYAN}prestashop${NC} (Abuso recursos/DoS)"
    echo -e " 2) ${CYAN}prestashop-scraper${NC} (Bots mudos/Scrapers)"
    echo -e " 3) ${CYAN}prestashop-proactive${NC} (Hackers/Exploits)"
    echo -e " 4) ${CYAN}apache-badbots${NC} (Bots)"
    echo -e " 5) ${CYAN}wordpress${NC}"
    echo -e " 6) ${CYAN}postfix${NC} (Mail)"
    echo -e " 7) ${CYAN}proftpd${NC} (FTP)"
    echo -e "${AZUL}--------------------------------------------------------------${NC}"
    read -p " Selecciona Jail2Ban a mostrar: " opcion
    case $opcion in
        1) JAIL_NAME="prestashop" ;;
        2) JAIL_NAME="prestashop-scraper" ;;
        3) JAIL_NAME="prestashop-proactive" ;;
        4) JAIL_NAME="apache-badbots" ;;
        5) JAIL_NAME="wordpress" ;;
        6) JAIL_NAME="postfix" ;;
        7) JAIL_NAME="proftpd" ;;
        *) exit 1 ;;
    esac
else
    JAIL_NAME=$1
fi

# ===============================================================
# BUCLE PRINCIPAL (MONITOR)
# ===============================================================
while true; do
    clear
    echo -e "${AZUL}╔══════════════════════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${AZUL}║${NC}       ${BLANCO}MONITOR DE SEGURIDAD AIRSOFT GANDIA${NC}                                    ${AZUL}║${NC}"
    echo -e "${AZUL}╚══════════════════════════════════════════════════════════════════════════════╝${NC}"

    # 1. ESTADO GLOBAL
    echo -e "${BG_AZUL}  1. ESTADO GLOBAL DEL SERVIDOR                                                 ${NC}"
    N_CPUS=$(nproc)
    LOAD_STR=$(uptime | awk -F'load average:' '{ print $2 }')
    LOAD_1MIN=$(echo $LOAD_STR | awk -F',' '{print $1}' | tr -d ' ')
    UMBRAL_OK=$(echo "$N_CPUS * 0.7" | bc)
    UMBRAL_WARN=$(echo "$N_CPUS * 1.0" | bc)
    if (( $(echo "$LOAD_1MIN < $UMBRAL_OK" | bc -l) )); then COL_LOAD=${VERDE}
    elif (( $(echo "$LOAD_1MIN < $UMBRAL_WARN" | bc -l) )); then COL_LOAD=${BG_AMARILLO}
    else COL_LOAD=${BG_ROJO}; fi
    echo -e " Núcleos: ${CYAN}$N_CPUS${NC} | Carga CPU: ${COL_LOAD}${LOAD_STR}${NC}\n"

    # 2. TRÁFICO RECIENTE
    echo -e "${BG_AZUL}  2. TRÁFICO RECIENTE + REPUTACIÓN (AbuseIPDB)                                  ${NC}"
    echo -e "${AZUL}  Pets |      IP       |       País         | Reputación / ISP${NC}"
    echo " ------------------------------------------------------------------------------"
    tail -n 5000 $LOG_PATH 2>/dev/null | awk '{print $1}' | sort | uniq -c | sort -nr | head -n 10 | while read count ip; do
        [ "$count" -gt 500 ] && COL_REQ=${BG_ROJO} || COL_REQ=${VERDE}
        pais_completo=$(geoiplookup $ip 2>/dev/null | head -n 1 | sed 's/.*, //' | cut -c1-18)
        [ -z "$pais_completo" ] && pais_completo="Local/Desconocido"
        reputacion=$(check_abuse $ip)
        printf "  ${COL_REQ}%4s${NC} | %-14s | %-18s | %b\n" "$count" "$ip" "$pais_completo" "$reputacion"
    done

    # 3. IPTABLES
    echo -e "\n${BG_AZUL}  3. MURO MANUAL (Iptables DROP)                                                ${NC}"
    echo -e "${AZUL}   Paquetes  |      IP / RANGO     |   País${NC}"
    echo " ------------------------------------------------------------------------------"
    sudo iptables -L INPUT -n -v | grep "DROP" | awk '{print $1, $8}' | sort -hr | while read pkts source; do
        pkts_clean=$(echo $pkts | sed 's/[a-zA-Z]//g' | cut -d'.' -f1)
        [ "${pkts_clean:-0}" -gt 0 ] && COL_P=${BG_ROJO} || COL_P=${VERDE}
        IP_C=$(echo $source | cut -d'/' -f1)
        pais=$(geoiplookup $IP_C 2>/dev/null | head -n 1 | sed 's/.*, //' | cut -c1-20)
        printf "  ${COL_P}%10s${NC} | ${CYAN}%-19s${NC} | %s\n" "$pkts" "$source" "${pais:-?}"
    done

    # 4. FAIL2BAN
    echo -e "\n${BG_AZUL}  4. MURO AUTOMÁTICO (Fail2Ban): ${BLANCO}${JAIL_NAME^^}                     ${NC}"
    JAIL_STATUS=$(sudo fail2ban-client status $JAIL_NAME)
    BAN_TIME_SEC=$(sudo fail2ban-client get $JAIL_NAME bantime)
    BAN_TIME_HORAS=$(awk "BEGIN {print $BAN_TIME_SEC/3600}")
    TOTAL_BAN=$(echo "$JAIL_STATUS" | grep "Currently banned:" | awk '{print $4}')
    LISTA_IPs=$(echo "$JAIL_STATUS" | grep "IP list" | sed 's/.*IP list:[[:space:]]*//' | tr ',' ' ' | tr -s ' ' '\n' | grep -v '^$' | tail -n 10)

    if [ -z "$LISTA_IPs" ] || [ "$TOTAL_BAN" -eq 0 ]; then
        echo -e "${AZUL}  Total IPs bloqueadas: 0${NC}"
    else
        echo -e "${AZUL}  Total: ${BG_ROJO}${BLANCO}${TOTAL_BAN}${NC}${AZUL} | Tiempo castigo: ${BAN_TIME_HORAS}h | Últimos 10:${NC}"
        echo -e "  ${AZUL} Fecha / Hora       |      IP / RANGO      | País / Reputación${NC}"
        echo -e " ------------------------------------------------------------------------------"
        while read -r ip; do
            [ -z "$ip" ] && continue
            FECHA_RAW=$(grep "Ban $ip" /var/log/fail2ban.log | tail -n 1 | awk '{print $1" "$2}' | cut -d',' -f1)
            [ -n "$FECHA_RAW" ] && FECHA_ES=$(echo "$FECHA_RAW" | awk -F'[- ]' '{print $3"/"$2"/"$1" "$4}') || FECHA_ES="Antigua/Descon."
            PAIS_NOMBRE=$(geoiplookup "$ip" | head -n 1 | sed 's/.*, //' | cut -c1-15)
            REPUTACION=$(check_abuse "$ip")
            printf "  ${BLANCO}%-19s${NC} | ${VERDE}%-20s${NC} | %-15s | %b\n" "$FECHA_ES" "$ip" "$PAIS_NOMBRE" "$REPUTACION"
        done <<< "$LISTA_IPs"
    fi
    echo -e "${AZUL}------------------------------------------------------------------------------${NC}"

    # 5. MENÚ VERTICAL
    echo -e "\n${BG_AMARILLO}  [!] MENU DE OPCIONES                                                        ${NC}"
    echo -e "  (${CYAN}I${NC}) Inspeccionar IP"
    echo -e "  (${BG_ROJO}B${NC}) Banear IP/Rango"
    echo -e "  (${CYAN}U${NC}) Desbanear IP/Rango"
    echo -e "  (${VERDE}R${NC}) Refrescar"
    echo -e "  (${BLANCO}S${NC}) Salir"
    echo -e "${AZUL}==============================================================================${NC}"

    read -n 1 -p " Selecciona una opción: " accion
    case $accion in
        i|I) echo ""; read -p " IP: " IP_I; inspect_ip $IP_I ;;
        b|B) ban_ip_manual ;;
        u|U) echo ""; read -p " IP: " IP_U; unban_ip $IP_U ;;
        r|R) continue ;;
        s|S) clear; exit 0 ;;
    esac
done