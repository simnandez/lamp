# --- CONFIGURACIÓN DE INSTALACIÓN ---
PHP_VERSIONS = ["5.6", "7.0", "7.1", "7.2", "7.3", "7.4", "8.0", "8.1", "8.2", "8.3", "8.4", "8.5"]
PHP_API = {
    "5.6": "20131226", "7.0": "20151012", "7.1": "20160303", "7.2": "20170718",
    "7.3": "20180731", "7.4": "20190902", "8.0": "20200930", "8.1": "20210902",
    "8.2": "20220829", "8.3": "20230831", "8.4": "20240924", "8.5": "20250925"
}

# --- CONFIGURACIÓN DE GETTEXT GLOBAL ---
LOCALE_DIR = '/usr/share/locale'
if not os.path.exists(os.path.join(LOCALE_DIR, 'es', 'LC_MESSAGES', 'lamp_installer.mo')):
    LOCALE_DIR = os.path.join(os.path.dirname(os.path.abspath(__file__)), 'locale')

try:
    sys_locale = QLocale.system().name().split('_')[0]
    initial_lang = sys_locale if sys_locale in ["es", "en"] else "en"
    _lang_obj = gettext.translation('lamp_installer', localedir=LOCALE_DIR, languages=[initial_lang], fallback=True)
    _lang_obj.install()
    _ = _lang_obj.gettext
except Exception:
    _ = gettext.gettext

class InstallWorker(QThread):
    log_signal = pyqtSignal(str)
    finished_signal = pyqtSignal(bool)

    def __init__(self, tasks, php_states, db_pass=""):
        super().__init__()
        self.tasks = tasks
        self.php_states = php_states
        self.db_pass = db_pass
        
        real_uid = None
        if os.environ.get('SUDO_UID'):
            real_uid = int(os.environ.get('SUDO_UID'))
        elif os.environ.get('PKEXEC_UID'):
            real_uid = int(os.environ.get('PKEXEC_UID'))
        else:
            try:
                with open('/proc/self/loginuid', 'r') as f:
                    luid = f.read().strip()
                    if luid and luid != '4294967295':
                        real_uid = int(luid)
            except Exception:
                pass

        if real_uid is not None and real_uid != 0:
            self.real_user = pwd.getpwuid(real_uid)[0]
        else:
            self.real_user = os.environ.get('SUDO_USER') or pwd.getpwuid(os.getuid())[0]
        
        try:
            user_info = pwd.getpwnam(self.real_user)
            self.user_home = user_info.pw_dir
            self.user_uid = user_info.pw_uid
            self.user_gid = user_info.pw_gid
        except KeyError:
            self.user_home = os.path.expanduser(f"~{self.real_user}")
            self.user_uid = os.getuid()
            self.user_gid = os.getgid()

    def run_cmd(self, cmd, desc):
        self.log_signal.emit(_("<b>[RUNNING]</b> {}...").format(desc))
        process = subprocess.Popen(cmd, shell=True, stdout=subprocess.PIPE, stderr=subprocess.STDOUT, text=True)
        for line in process.stdout:
            self.log_signal.emit(f"<span style='color: #888;'>&nbsp;&nbsp;{line.strip()}</span>")
        process.wait()
        return process.returncode == 0

    def create_autostart(self):
        dir_path = os.path.join(self.user_home, ".config", "autostart")
        file_path = os.path.join(dir_path, "lamp-tray.desktop")
        content = "[Desktop Entry]\nExec=lamp-tray\nIcon=network-server\nName=lamp-tray\nTerminal=false\nType=Application\n"
        try:
            os.makedirs(dir_path, exist_ok=True)
            with open(file_path, "w") as f: 
                f.write(content)
            
            os.chown(file_path, self.user_uid, self.user_gid)
            os.chown(dir_path, self.user_uid, self.user_gid)
            
            self.log_signal.emit(_("<span style='color: #27ae60;'>✔ Autostart successfully created in '{}'s Home.</span>").format(self.real_user))
        except Exception as e:
            self.log_signal.emit(_("<span style='color: #e74c3c;'>✘ Autostart error: {}</span>").format(e))

    def setup_tmpfs_logs(self):
        conf = "d /var/log/apache2 755 root adm -\nd /var/log/mysql 2755 mysql adm -\n"
        try:
            with open('/etc/tmpfiles.d/tmpfslogs.conf', 'w') as f: f.write(conf)
            self.log_signal.emit(_("<span style='color: #27ae60;'>✔ RAM logs configured (tmpfs).</span>"))
        except Exception as e:
            self.log_signal.emit(_("✘ tmpfs error: {}").format(e))

    def run(self):
        # 1. ACTUALIZACIÓN E INSTALACIÓN BASE
        if self.tasks['base']:
            self.run_cmd("apt update && apt install -y apache2 mariadb-server php php-mysql wget lsb-release ca-certificates apt-transport-https gnupg2 curl", _("Base Installation"))
        else:
            self.run_cmd("apt purge -y apache2 mariadb-server apache2-bin mariadb-client && apt autoremove -y", _("Base Uninstallation (Apache & MariaDB)"))
            
        # 2. CONFIGURACIÓN DE SEGURIDAD MARIADB
        if self.tasks['sql_sec']:
            safe_pass = self.db_pass.replace("'", "'\\''")
            sql_script = f"""
            mysql -u root -e "ALTER USER 'root'@'localhost' IDENTIFIED BY '{safe_pass}';"
            export MYSQL_PWD="{safe_pass}"
            mysql -u root -e "DELETE FROM mysql.user WHERE User='';"
            mysql -u root -e "DELETE FROM mysql.user WHERE User='root' AND Host NOT IN ('localhost', '127.0.0.1', '::1');"
            mysql -u root -e "DROP DATABASE IF EXISTS test;"
            mysql -u root -e "DELETE FROM mysql.db WHERE Db='test' OR Db='test\\_%';"
            mysql -u root -e "GRANT ALL PRIVILEGES ON *.* TO 'root'@'localhost' IDENTIFIED BY '{safe_pass}' WITH GRANT OPTION;"
            mysql -u root -e "FLUSH PRIVILEGES;"
            unset MYSQL_PWD
            """
            self.run_cmd(sql_script, _("Securing MariaDB (full cleanup)"))

        # 3. MODO NO ESTRICTO MARIADB
        if self.tasks['sql_mode']:
            path = '/etc/mysql/conf.d/disable_strict_mode.cnf.back'
            conf = "[mysqld]\nsql_mode=ONLY_FULL_GROUP_BY,STRICT_TRANS_TABLES,NO_ZERO_IN_DATE,NO_ZERO_DATE,ERROR_FOR_DIVISION_BY_ZERO,NO_ENGINE_SUBSTITUTION\n"
            with open(path, 'w') as f: f.write(conf)

        # 4. REPOSITORIO SURY
        if self.tasks['sury']:
            cmd = "apt-get install -y extrepo && extrepo enable sury && apt update"
            self.run_cmd(cmd, _("PHP Repository"))
        else:
            if os.path.exists("/etc/apt/sources.list.d/php.list"):
                self.run_cmd("rm /etc/apt/sources.list.d/php.list && rm /usr/share/keyrings/deb.sury.org-php.gpg && apt update", _("Removing PHP Repository"))

        # 5. INSTALACIÓN DE VERSIONES DE PHP Y GENERACIÓN COMPLETA DE XDEBUG.INI
        for ver, install in self.php_states.items():
            if install:
                libs = f"php{ver} libapache2-mod-php{ver} php{ver}-xdebug php{ver}-curl php{ver}-gd php{ver}-xml php{ver}-mysql php{ver}-mbstring php{ver}-soap php{ver}-intl php{ver}-zip php{ver}-imap php{ver}-cgi"
                if ver in ["5.6", "7.0", "7.1"]:
                    libs += f" php{ver}-mcrypt php{ver}-xmlrpc"

                if self.run_cmd(f"apt install -y {libs}", _("Installing PHP {} and extensions").format(ver)):
                    ini = f"/etc/php/{ver}/mods-available/xdebug.ini"
                    if os.path.exists(os.path.dirname(ini)):
                        api = PHP_API.get(ver, "unknown")
                        
                        # Lista nativa limpia para evitar alertas de escape y volcar toda la config
                        config_lines = [
                            f'zend_extension="/usr/lib/php/{api}/xdebug.so"',
                            'xdebug.remote_enable=1',
                            'xdebug.remote_handler=dbgp',
                            'xdebug.remote_mode=req',
                            'xdebug.remote_host=127.0.0.1',
                            'xdebug.remote_port=9003',
                            'xdebug.max_nesting_level=300',
                            'xdebug.mode=debug'
                        ]
                        with open(ini, 'w') as f:
                            f.write('\n'.join(config_lines) + '\n')
            else:
                if os.path.exists(f"/etc/php/{ver}"):
                    self.run_cmd(f"apt purge -y php{ver}* && apt autoremove -y", _("Uninstalling PHP {}").format(ver))

        # 6. APACHE Y PERMISOS
        if self.tasks['apache']:
            cmds = fr"""
            a2enmod rewrite > /dev/null 2>&1
            CONF_FILE="/etc/apache2/sites-available/000-default.conf"

            if ! grep -q "<Directory /var/www/html>" "$CONF_FILE"; then
                sed -i '/DocumentRoot \/var\/www\/html/a \
                <Directory /var/www/html>\
                    Options Indexes FollowSymLinks\
                    AllowOverride All\
                    Require all granted\
                </Directory>' "$CONF_FILE"
            fi

            chown -R www-data:www-data /var/www/html
            find /var/www/html -type d -exec chmod 2775 {{}} \;
            find /var/www/html -type f -exec chmod 0664 {{}} \;
            usermod -aG www-data {self.real_user}
            """
            self.run_cmd(cmds, _("Apache & Permissions"))
        else:
            self.run_cmd("a2dismod rewrite", _("Disabling ModRewrite"))

        # 7. LOGS EN RAM (TMPFS)
        if self.tasks['tmpfs']:
            self.setup_tmpfs_logs()
        else:
            if os.path.exists('/etc/tmpfiles.d/tmpfslogs.conf'):
                os.remove('/etc/tmpfiles.d/tmpfslogs.conf')
                self.log_signal.emit(_("<span style='color: #e67e22;'>✔ tmpfs configuration removed.</span>"))

        # 8. AUTOSTART DEL TRAY
        if self.tasks['autostart']:
            self.create_autostart()
        else:
            path = os.path.join(self.user_home, ".config", "autostart", "lamp-tray.desktop")
            if os.path.exists(path):
                os.remove(path)
                self.log_signal.emit(_("<span style='color: #e67e22;'>✔ Autostart removed.</span>"))

        # REINICIO FINAL DE SERVICIOS
        self.run_cmd("systemctl restart apache2 mariadb", _("Restarting System Services"))
        
        self.finished_signal.emit(True)

class LampGui(QMainWindow):
    def __init__(self):
        super().__init__()
        self.setMinimumSize(720, 800)
        
        sys_locale = QLocale.system().name().split('_')[0]
        self.current_lang = sys_locale if sys_locale in ["en", "es"] else "en"
            
        self.init_ui()
        self.update_language(self.current_lang)

    def init_ui(self):
        central = QWidget()
        self.real_user = os.environ.get('SUDO_USER') or pwd.getpwuid(os.getuid())[0]
        self.setCentralWidget(central)
        layout = QVBoxLayout(central)
        layout.setSpacing(8)
        
        top_bar = QHBoxLayout()
        top_bar.addStretch()
        self.combo_lang = QComboBox()
        self.combo_lang.addItems(["en", "es"])
        self.combo_lang.setCurrentText(self.current_lang)
        self.combo_lang.currentTextChanged.connect(self.update_language)
        top_bar.addWidget(self.combo_lang)
        layout.addLayout(top_bar)

        self.title_label = QLabel()
        self.title_label.setFont(QFont("sans-serif", 16, QFont.Weight.Bold))
        self.title_label.setAlignment(Qt.AlignmentFlag.AlignCenter)
        layout.addWidget(self.title_label)

        scroll = QScrollArea()
        scroll.setWidgetResizable(True)
        scroll.setFrameShape(QFrame.Shape.NoFrame)
        scroll_content = QWidget()
        self.opts_layout = QVBoxLayout(scroll_content)

        self.g_base = QGroupBox()
        v_base = QVBoxLayout()
        self.chk_base = QCheckBox()
        self.chk_sql_sec = QCheckBox()
        self.chk_sql_mode = QCheckBox()
        for c in [self.chk_base, self.chk_sql_sec, self.chk_sql_mode]: v_base.addWidget(c)
        self.g_base.setLayout(v_base)
        self.opts_layout.addWidget(self.g_base)

        self.g_php = QGroupBox()
        v_php = QVBoxLayout()
        self.chk_sury = QCheckBox()
        v_php.addWidget(self.chk_sury)
        php_grid = QWidget()
        grid = QHBoxLayout(php_grid)
        grid.setContentsMargins(10,0,0,0)
        self.php_checks = {}
        c1, c2 = QVBoxLayout(), QVBoxLayout()
        for i, v in enumerate(PHP_VERSIONS):
            cb = QCheckBox(f"PHP {v}")
            self.php_checks[v] = cb
            cb.toggled.connect(self.update_sury_checkbox)
            if i < 6: c1.addWidget(cb)
            else: c2.addWidget(cb)
        grid.addLayout(c1)
        grid.addLayout(c2)
        v_php.addWidget(php_grid)
        self.g_php.setLayout(v_php)
        self.opts_layout.addWidget(self.g_php)

        self.g_ext = QGroupBox()
        v_ext = QVBoxLayout()
        self.chk_apache = QCheckBox()
        self.chk_tmpfs = QCheckBox()
        self.chk_autostart = QCheckBox()
        for c in [self.chk_apache, self.chk_tmpfs, self.chk_autostart]: v_ext.addWidget(c)
        self.g_ext.setLayout(v_ext)
        self.opts_layout.addWidget(self.g_ext)

        scroll.setWidget(scroll_content)
        layout.addWidget(scroll, stretch=1)

        self.detect_installed_components()

        self.console = QTextEdit()
        self.console.setReadOnly(True)
        self.console.setFixedHeight(160)
        self.console.setStyleSheet("""QTextEdit {background-color: #000000;color: #FFFFFF;font-family: 'Monospace';font-size: 10pt;border: 1px solid #444444;}""")
        layout.addWidget(self.console)

        self.btn = QPushButton()
        self.btn.setFixedHeight(50)
        self.btn.clicked.connect(self.start_process)
        layout.addWidget(self.btn)

    def update_language(self, lang_code):
        global _
        self.current_lang = lang_code
        try:
            lang_obj = gettext.translation('lamp_installer', localedir=LOCALE_DIR, languages=[lang_code])
            lang_obj.install()
            _ = lang_obj.gettext
        except Exception:
            _ = gettext.gettext
        
        self.setWindowTitle(_("LAMP Installer 8.5.1"))
        self.title_label.setText(_("LAMP Stack installer"))
        
        self.g_base.setTitle(_("Base Installation"))
        self.chk_base.setText(_("Install Apache2, MariaDB and PHP"))
        self.chk_sql_sec.setText(_("Secure MariaDB and configure root"))
        self.chk_sql_mode.setText(_("Enable STRICT MODE in MariaDB"))
        
        self.g_php.setTitle(_("PHP (Sury.org Repository)"))
        self.chk_sury.setText(_("Add multiple PHP versions repository"))
        
        self.g_ext.setTitle(_("Apache configuration & permissions"))
        self.chk_apache.setText(_("Enable ModRewrite and adjust /var/www/html permissions"))
        self.chk_tmpfs.setText(_("Move logs to RAM (tmpfs) - Recommended for SSD"))
        self.chk_autostart.setText(_("Add 'Lamp tray' to Autostart"))
        
        self.btn.setText(_(" SYNCHRONIZE CHANGES (INSTALL / UNINSTALL)"))

    def detect_installed_components(self):
        def is_installed(pkg):
            return subprocess.call(["dpkg", "-s", pkg], stdout=subprocess.DEVNULL, stderr=subprocess.STDOUT) == 0

        if is_installed("apache2") or is_installed("mariadb-server"):
            self.chk_base.setChecked(True)

        if os.path.exists("/etc/apt/sources.list.d/php.list"):
            self.chk_sury.setChecked(True)

        for ver, cb in self.php_checks.items():
            if is_installed(f"php{ver}"):
                cb.setChecked(True)

        if os.path.exists('/etc/tmpfiles.d/tmpfslogs.conf'):
            self.chk_tmpfs.setChecked(True)

        user_home = pwd.getpwnam(self.real_user).pw_dir
        if os.path.exists(os.path.join(user_home, ".config", "autostart", "lamp-tray.desktop")):
            self.chk_autostart.setChecked(True)

    def update_sury_checkbox(self):
        any_php_selected = any(cb.isChecked() for cb in self.php_checks.values())
        if any_php_selected:
            self.chk_sury.setChecked(True)

    def log(self, text):
        self.console.append(text)
        self.console.verticalScrollBar().setValue(self.console.verticalScrollBar().maximum())

    def start_process(self):
        if os.geteuid() != 0:
            QMessageBox.critical(self, _("Error"), _("You must run this as root."))
            return
            
        tasks = {
            'base': self.chk_base.isChecked(), 'sql_sec': self.chk_sql_sec.isChecked(),
            'sql_mode': self.chk_sql_mode.isChecked(), 'sury': self.chk_sury.isChecked(),
            'apache': self.chk_apache.isChecked(), 'tmpfs': self.chk_tmpfs.isChecked(),
            'autostart': self.chk_autostart.isChecked()
        }
        
        db_password = ""
        if tasks['sql_sec']:
            password, ok = QInputDialog.getText(
                self, 
                _("Database Password"), 
                _("Enter new password for MariaDB root user:"), 
                QLineEdit.EchoMode.Password
            )
            if not ok:
                return 
            db_password = password
            
        php_states = {v: cb.isChecked() for v, cb in self.php_checks.items()}
        
        self.btn.setEnabled(False)
        self.console.clear()
        
        self.worker = InstallWorker(tasks, php_states, db_password)
        self.worker.log_signal.connect(self.log)
        self.worker.finished_signal.connect(lambda: self.btn.setEnabled(True))
        self.worker.start()

if __name__ == "__main__":
    app = QApplication(sys.argv)
    app.setStyle("Fusion")
    win = LampGui()
    win.show()
    sys.exit(app.exec())