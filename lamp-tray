#!/usr/bin/env python3

import sys
import os
import subprocess
import glob
import gettext
from PyQt6.QtWidgets import QApplication, QSystemTrayIcon, QMenu
from PyQt6.QtGui import QIcon, QAction, QPixmap, QPainter, QColor, QPen, QBrush
from PyQt6.QtCore import QTimer, Qt

# --- CONFIGURACIÓN DE GETTEXT (LOCALIZACIÓN) ---
LOCALE_DIR = '/usr/share/locale'
if not os.path.exists(os.path.join(LOCALE_DIR, 'es', 'LC_MESSAGES', 'lamp_tray.mo')):
    LOCALE_DIR = os.path.join(os.path.dirname(os.path.abspath(__file__)), 'locale')

# Inicializa gettext buscando el dominio 'lamp_indicator'
# fallback=True asegura que si no encuentra el idioma del sistema, use los strings originales en inglés del código.
lang = gettext.translation('lamp_tray', localedir=LOCALE_DIR, fallback=True)
lang.install()
# Esto inyecta la función _() de forma global en el script.
_ = lang.gettext

# --- CONFIGURACIÓN DEL SCRIPT ---
STRICT_MODE_FILE = "/etc/mysql/conf.d/enable_strict_mode.cnf"
STRICT_MODE_BACKUP = "/etc/mysql/conf.d/enable_strict_mode.cnf.back"

def to_bold_unicode(text):
    normal = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789"
    bold = "𝗔𝗕𝗖𝗗Ｅ𝗙𝗚𝗛𝗜𝗝𝗞𝗟𝗠𝗡𝗢Ｐ𝗤𝗥𝗦𝗧𝗨𝑽𝗪𝗫𝗬𝗭𝗮𝗯𝗰𝗱𝗲𝗳𝗴𝗵𝗶𝗷𝗸𝗹𝗺𝗻𝗼𝗽𝗾𝗿𝘀𝘁𝘂𝒗𝘄𝗫𝘆𝘇𝟬𝟭𝟮𝟯𝟰𝟱𝟲𝟳𝟴𝟵"
    table = str.maketrans(normal, bold)
    return text.translate(table)

def get_db_service():
    if subprocess.run("systemctl list-unit-files mariadb.service", shell=True, capture_output=True).returncode == 0:
        return "mariadb"
    return "mysql"

def get_active_php():
    try:
        cmd = "php -r 'echo PHP_MAJOR_VERSION.\".\".PHP_MINOR_VERSION;'"
        return subprocess.check_output(cmd, shell=True, text=True).strip()
    except:
        return "N/A"

class LampIndicator:
    def __init__(self):
        self.app = QApplication(sys.argv)
        self.app.setQuitOnLastWindowClosed(False)
        self.db_service = get_db_service()

        self.menu = QMenu()
        self.tray = QSystemTrayIcon()
        self.tray.setContextMenu(self.menu)

        self.timer = QTimer()
        self.timer.timeout.connect(self.update_ui)
        self.timer.start(4000)

        self.update_ui()
        self.tray.show()

    def create_custom_round_icon(self, color_hex):
        pixmap = QPixmap(22, 22)
        pixmap.fill(Qt.GlobalColor.transparent)
        painter = QPainter(pixmap)
        painter.setRenderHint(QPainter.RenderHint.Antialiasing)
        color = QColor(color_hex)
        painter.setPen(QPen(color.darker(140), 1.2))
        painter.setBrush(QBrush(color))
        painter.drawEllipse(3, 3, 16, 16)
        painter.setPen(Qt.PenStyle.NoPen)
        painter.setBrush(QBrush(QColor(255, 255, 255, 60)))
        painter.drawEllipse(6, 4, 10, 5)
        painter.setPen(QPen(Qt.GlobalColor.white, 2.5))
        painter.drawLine(9, 8, 9, 14)
        painter.drawLine(9, 14, 13, 14)
        painter.end()
        return QIcon(pixmap)

    def create_dot_icon(self, color_hex, size=14):
        pixmap = QPixmap(size, size)
        pixmap.fill(Qt.GlobalColor.transparent)
        painter = QPainter(pixmap)
        painter.setRenderHint(QPainter.RenderHint.Antialiasing)
        painter.setBrush(QColor(color_hex))
        painter.setPen(Qt.PenStyle.NoPen)
        painter.drawEllipse(0, 0, size, size)
        painter.end()
        return QIcon(pixmap)

    def run_gui_sudo(self, cmd):
        full_cmd = f"pkexec bash -c '{cmd}'"
        try:
            subprocess.Popen(full_cmd, shell=True)
        except Exception as e:
            print(f"Error al lanzar pkexec: {e}")

    def update_ui(self):
        apache_active = subprocess.run("systemctl is-active --quiet apache2", shell=True).returncode == 0
        db_active = subprocess.run(f"systemctl is-active --quiet {self.db_service}", shell=True).returncode == 0
        is_strict = os.path.exists(STRICT_MODE_FILE)
        active_php = get_active_php()

        color = "#27ae60" if apache_active and db_active else "#e74c3c"
        self.tray.setIcon(self.create_custom_round_icon(color))

        # Uso de traducciones de gettext mediante _()
        st_ap = _("● ON") if apache_active else _("○ OFF")
        st_db = _("● ON") if db_active else _("○ OFF")
        st_str = _("▲ ACTIVE") if is_strict else _("DISABLED")

        titulo_bold = to_bold_unicode(_("LAMP SERVICES STATUS"))
        self.tray.setToolTip(
            f"{titulo_bold}\n\n"
            f"Apache: {st_ap}\n"
            f"{self.db_service.capitalize()}: {st_db}\n"
            f"Strict Mode: {st_str}\n"
            f"PHP: {active_php}"
        )

        if self.menu.isHidden():
            self.refresh_menu(apache_active, db_active, is_strict, active_php)

    def refresh_menu(self, apache_on, db_on, is_strict, active_php):
        self.menu.clear()
        VERDE, ROJO = "#27ae60", "#e74c3c"

        # Formateo dinámico con cadenas traducidas
        apache_status = _("ON") if apache_on else _("OFF")
        self.menu.addAction(self.create_dot_icon(VERDE if apache_on else ROJO), _("Apache: {}").format(apache_status))
        
        db_status = _("ON") if db_on else _("OFF")
        self.menu.addAction(self.create_dot_icon(VERDE if db_on else ROJO), _("{}: {}").format(self.db_service.upper(), db_status))
        
        strict_status = _("ACTIVE") if is_strict else _("INACTIVE")
        self.menu.addAction(self.create_dot_icon(ROJO if is_strict else VERDE), _("Strict Mode: {}").format(strict_status))
        self.menu.addSeparator()

        # Botones de Control
        self.menu.addAction(QIcon.fromTheme("media-playback-start"), _("Start LAMP"),
                           lambda: self.run_gui_sudo(f"systemctl start apache2 {self.db_service}"))
        self.menu.addAction(QIcon.fromTheme("view-refresh"), _("Restart LAMP"),
                           lambda: self.run_gui_sudo(f"systemctl restart apache2 {self.db_service}"))
        self.menu.addAction(QIcon.fromTheme("media-playback-stop"), _("Stop LAMP"),
                           lambda: self.run_gui_sudo(f"systemctl stop apache2 {self.db_service}"))
        self.menu.addSeparator()

        # Toggle Strict Mode
        label_st = _("Disable Strict Mode") if is_strict else _("Enable Strict Mode")
        self.menu.addAction(QIcon.fromTheme("security-high"), label_st, lambda: self.toggle_strict(not is_strict))
        self.menu.addSeparator()

        # Selector de Versión PHP
        php_paths = sorted(glob.glob("/usr/bin/php[0-9].[0-9]"), reverse=True)
        for path in php_paths:
            ver = os.path.basename(path).replace("php", "")
            is_act = (ver == active_php)
            icon = QIcon.fromTheme("emblem-success-symbolic") if is_act else QIcon()
            
            # gettext traduce la plantilla base, y luego inyectamos la versión y aplicamos negrita si corresponde
            label = to_bold_unicode(_("PHP {} (ACTIVE)").format(ver)) if is_act else f"PHP {ver}"
            action = QAction(icon, label, self.menu)
            action.triggered.connect(lambda checked, v=ver: self.change_php(v))
            self.menu.addAction(action)

        self.menu.addSeparator()
        self.menu.addAction(QIcon.fromTheme("application-exit"), _("Exit"), self.app.quit)

    def toggle_strict(self, activate):
        if activate:
            self.run_gui_sudo(f"cp {STRICT_MODE_BACKUP} {STRICT_MODE_FILE} && systemctl restart {self.db_service}")
        else:
            self.run_gui_sudo(f"rm -f {STRICT_MODE_FILE} && systemctl restart {self.db_service}")

    def change_php(self, v):
        cmd = (
            f"for mod in /etc/apache2/mods-enabled/php*.load; do "
            f"  [ -e \"$mod\" ] && a2dismod \"$(basename \"$mod\" .load)\"; "
            f"done; "
            f"a2enmod php{v} && "
            f"update-alternatives --set php /usr/bin/php{v} && "
            f"systemctl restart apache2"
        )
        self.run_gui_sudo(cmd)

if __name__ == "__main__":
    indicator = LampIndicator()
    sys.exit(indicator.app.exec())