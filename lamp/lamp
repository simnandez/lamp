#!/bin/bash

# --- ConfiguraciГіn y AutodetecciГіn de PHP ---
# Buscamos binarios phpX.X en /usr/bin, extraemos el nГәmero y ordenamos por versiГіn
VERSIONES_PHP=($(ls /usr/bin/php[0-9].* 2>/dev/null | sed 's/.*php//' | sort -V))

STRICT_MODE_FILE="/etc/mysql/conf.d/enable_strict_mode.cnf"
STRICT_MODE_BACKUP="/etc/mysql/conf.d/enable_strict_mode.cnf.back"

# Si no se encuentra ninguna versiГіn, avisamos
if [ ${#VERSIONES_PHP[@]} -eq 0 ]; then
    echo -e "\e[31mвҡ  No se detectГі ninguna versiГіn de PHP instalada en /usr/bin/\e[0m"
    exit 1
fi

# --- AutodetecciГіn de Base de Datos ---
if systemctl list-unit-files mariadb.service >/dev/null 2>&1; then
    DB_SERVICE="mariadb"
elif systemctl list-unit-files mysql.service >/dev/null 2>&1; then
    DB_SERVICE="mysql"
else
    DB_SERVICE=""
fi

# Colores y Estilos
BOLD='\e[1m'
CYAN='\e[36m'
GREEN='\e[32m'
YELLOW='\e[33m'
RED='\e[31m'
MAGENTA='\e[35m'
NC='\e[0m'

# --- Funciones de Interfaz ---
_pausa() {
    echo -e "\n  ${MAGENTA}вһ”${NC} Presiona cualquier tecla para volver al menГә..."
    read -n 1 -s -r
}

_progreso() {
    local pid=$1
    local mensaje=$2
    local spin='в Ӣв ҷв №в ёв јв ҙв Ұв §в Үв Ҹ'
    echo -ne "  ${YELLOW}$mensaje${NC}  "
    while kill -0 $pid 2>/dev/null; do
        for i in {0..9}; do
            echo -ne "\b${spin:$i:1}"
            sleep 0.1
        done
    done
    wait $pid
    if [ $? -eq 0 ]; then
        echo -e "\b${GREEN}вң” Finalizado con Г©xito${NC}"
    else
        echo -e "\b${RED}вңҳ Hubo un error${NC}"
    fi
}

_info_actual() {
    local php_raw=$(php -v 2>/dev/null | head -n 1 | cut -d " " -f 2)
    local php_v=${php_raw%%+*}
    ST_APACHE=$(systemctl is-active --quiet apache2 && echo -e "${GREEN}в—Ҹ ACTIVO${NC}" || echo -e "${RED}в—Ӣ DESACTIVADO${NC}")

    if [ -n "$DB_SERVICE" ] && systemctl is-active --quiet "$DB_SERVICE"; then
        ST_MYSQL="${GREEN}в—Ҹ ACTIVO ($DB_SERVICE)${NC}"
    else
        ST_MYSQL="${RED}в—Ӣ DESACTIVADO${NC}"
    fi

    ST_STRICT=$([ -f "$STRICT_MODE_FILE" ] && echo -e "${GREEN}в—Ҹ ACTIVADO${NC}" || echo -e "${RED}в—Ӣ DESACTIVADO${NC}")

    echo -e "  в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ"
    echo -e "    ${BOLD}ESTADO DEL SISTEMA${NC}"
    echo ""
    echo -e "    ${CYAN}рҹҗҳ VersiГіn activa PHP:${NC}  ${php_v:-"No instalado"}"
    echo -e "    ${CYAN}рҹҢҗ Apache2:${NC}             $ST_APACHE"
    echo -e "    ${CYAN}рҹҗ¬ Base de Datos:${NC}       $ST_MYSQL"
    echo -e "    ${CYAN}рҹӣ   MySQL Strict Mode:${NC}   $ST_STRICT"
    echo -e "  в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ"
}

# --- Funciones de LГіgica ---
_cambiar_php() {
    local v=$1
    (
        current_mods=$(ls /etc/apache2/mods-enabled/php*.load 2>/dev/null | xargs -n1 basename 2>/dev/null | sed 's/.load//')
        for mod in $current_mods; do sudo a2dismod "$mod" >/dev/null 2>&1; done
        sudo a2enmod "php$v" >/dev/null 2>&1
        sudo update-alternatives --set php "/usr/bin/php$v" >/dev/null 2>&1
        sudo systemctl restart apache2
    ) &
    _progreso $! "Configurando PHP $v y reiniciando Apache"
}

_gestion_servicio() {
    local servicios=$1
    local accion=$2
    local mensaje=$3

    for srv in $servicios; do
        if ! systemctl list-unit-files "${srv}.service" >/dev/null 2>&1; then
            echo -e "${RED}вҡ  Error: El servicio '$srv' no estГЎ instalado.${NC}"
            return 1
        fi
    done

    sudo systemctl $accion $servicios >/dev/null 2>&1 &
    _progreso $! "$mensaje"
}

# --- MenГә ---
_menu() {
    clear
    # Obtenemos la versiГіn corta (ej: 8.2) para comparar en el bucle
    local php_activa_raw=$(php -v 2>/dev/null | head -n 1 | cut -d " " -f 2)
    local php_activa_short=$(echo "$php_activa_raw" | cut -d "." -f 1,2)

    echo -e "\n  ${BOLD}${MAGENTA}рҹҡҖ LAMP CONFIGURATOR PRO-EXPERT 8.5.1${NC}"
    echo -e "  ${CYAN}вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”${NC}"
    _info_actual

    echo -e "\n  ${BOLD}вҡЎ GESTIГ“N DE SERVICIOS${NC}"
    echo -e "  ${CYAN}[I]${NC} Iniciar LAMP"
    echo -e "  ${CYAN}[P]${NC} Parar LAMP"
    echo -e "  ${CYAN}[R]${NC} Reiniciar LAMP"
    echo ""
    echo -e "  ${CYAN}[A]${NC} Activar MySQL Strict Mode"
    echo -e "  ${CYAN}[D]${NC} Desactivar MySQL Strict Mode"

    echo -e "\n  ${BOLD}рҹҗҳ ACTIVAR VERSIГ“N DE PHP (Instaladas)${NC}"
    for i in "${!VERSIONES_PHP[@]}"; do
        local v_item="${VERSIONES_PHP[$i]}"
        if [[ "$v_item" == "$php_activa_short" ]]; then
            # Si coincide con la activa, resaltamos en verde y aГұadimos el tag
            printf "  ${CYAN}[%2d]${NC} ${GREEN}вһң PHP %s (ACTIVA)${NC}\n" $((i+1)) "$v_item"
        else
            printf "  ${CYAN}[%2d]${NC}   PHP %s\n" $((i+1)) "$v_item"
        fi
    done

    echo -e "\n  ${CYAN}[0]${NC} Salir"
    echo -e "  ${CYAN}вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”${NC}"
    echo -ne "  ${BOLD}Selecciona una opciГіn:${NC} "
}

# --- Bucle Principal ---
while :
do
    _menu
    read -r opc

    LAMP_SERVICES="apache2 $DB_SERVICE"

    case $opc in
        i|I)
            _gestion_servicio "$LAMP_SERVICES" start "Levantando servicios LAMP"
            _pausa ;;
        p|P)
            _gestion_servicio "$LAMP_SERVICES" stop "Deteniendo servicios LAMP"
            _pausa ;;
        r|R)
            _gestion_servicio "$LAMP_SERVICES" restart "Reiniciando servicios LAMP"
            _pausa ;;
        a|A)
            echo ""
            if [ -f "$STRICT_MODE_BACKUP" ]; then
                (sudo cp "$STRICT_MODE_BACKUP" "$STRICT_MODE_FILE" && sudo systemctl restart "$DB_SERVICE") &
                _progreso $! "Activando StrictMode"
            else
                echo -e "${RED}вҡ  Error: Archivo backup no encontrado en $STRICT_MODE_BACKUP${NC}"
            fi
            _pausa ;;
        d|D)
            echo ""
            (sudo rm -f "$STRICT_MODE_FILE" && sudo systemctl restart "$DB_SERVICE") &
            _progreso $! "Desactivando StrictMode"
            _pausa ;;
        [0-9]|[1-9][0-9])
            if [ "$opc" -eq 0 ]; then
                echo -e "\n  ${MAGENTA}рҹ‘Ӣ ВЎHasta luego $USER!${NC}\n"
                exit 0
            fi

            idx=$((opc-1))
            if [ $idx -ge 0 ] && [ $idx -lt "${#VERSIONES_PHP[@]}" ]; then
                _cambiar_php "${VERSIONES_PHP[$idx]}"
                _pausa
            else
                echo -e "\n  ${RED}вҡ  OpciГіn invГЎlida${NC}" ; sleep 1
            fi ;;
        *)
            echo -e "\n  ${RED}вҡ  OpciГіn invГЎlida${NC}" ; sleep 1 ;;
    esac
done