#!/bin/bash

# --- Configuración ---
VERSIONES_PHP=("5.6" "7.0" "7.1" "7.2" "7.3" "7.4" "8.0" "8.1" "8.2" "8.3" "8.4" "8.5")
STRICT_MODE_FILE="/etc/mysql/conf.d/enable_strict_mode.cnf"
STRICT_MODE_BACKUP="/etc/mysql/conf.d/enable_strict_mode.cnf.back"

# Colores y Estilos
BOLD='\e[1m'
CYAN='\e[36m'
GREEN='\e[32m'
YELLOW='\e[33m'
RED='\e[31m'
MAGENTA='\e[35m'
NC='\e[0m' # No Color

# --- Funciones de Interfaz ---

_pausa() {
    echo -e "\n  ${MAGENTA}➔${NC} Presiona cualquier tecla para volver al menú..."
    read -n 1 -s -r
}

_progreso() {
    local pid=$1
    local mensaje=$2
    local spin='⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏'
    echo -ne "  ${YELLOW}$mensaje${NC}  "
    while kill -0 $pid 2>/dev/null; do
        for i in {0..9}; do
            echo -ne "\b${spin:$i:1}"
            sleep 0.1
        done
    done
    wait $pid
    if [ $? -eq 0 ]; then
        echo -e "\b${GREEN}✔ Finalizado con éxito${NC}"
    else
        echo -e "\b${RED}✘ Hubo un error${NC}"
    fi
}

_info_actual() {
    # Tomamos la versión y cortamos todo lo que venga después del primer '+' o '~'
    # para que quede solo la versión base: 7.1.33...
    local php_raw=$(php -v 2>/dev/null | head -n 1 | cut -d " " -f 2)
    local php_v=$(echo "$php_raw" | cut -d "+" -f 1 | cut -d "~" -f 1)

    echo -e "  ┌──────────────────────────────────────────────────┐"
    echo -e "    ${BOLD}ESTADO DEL SISTEMA${NC}"
    echo -e "    ${CYAN}🐘 PHP Version:${NC}  ${php_v:-"No instalado"}"

    if [ -f "$STRICT_MODE_FILE" ]; then
        echo -e "    ${CYAN}🐬 MySQL Strict:${NC} ${GREEN}● ACTIVADO${NC}"
    else
        echo -e "    ${CYAN}🐬 MySQL Strict:${NC} ${RED}○ DESACTIVADO${NC}"
    fi
    echo -e "  └──────────────────────────────────────────────────┘"
}


# --- Funciones de Lógica ---

_cambiar_php() {
    local v=$1
    (
        current_mods=$(ls /etc/apache2/mods-enabled/php*.load 2>/dev/null | xargs -n1 basename | sed 's/.load//')
        for mod in $current_mods; do sudo a2dismod "$mod" >/dev/null 2>&1; done
        sudo a2enmod "php$v" >/dev/null 2>&1
        sudo ln -sfn "/usr/bin/php$v" /etc/alternatives/php
        sudo systemctl restart apache2
    ) &
    _progreso $! "Configurando PHP $v y reiniciando Apache"
}

_gestion_servicio() {
    sudo systemctl $1 $2 &
    _progreso $! "$3"
}

# --- Menú ---

_menu() {
    clear
    echo -e "\n  ${BOLD}${MAGENTA}🚀 LAMP CONFIGURATOR PRO-EXPERT 8.5${NC}"
    echo -e "  ${CYAN}——————————————————————————————————————————————————${NC}"
    _info_actual

    echo -e "\n  ${BOLD}⚡ GESTIÓN DE SERVICIOS${NC}"
    echo -e "  ${CYAN}[I]${NC} Iniciar LAMP      ${CYAN}[A]${NC} Activar MySQL Strict"
    echo -e "  ${CYAN}[P]${NC} Parar LAMP        ${CYAN}[D]${NC} Desactivar MySQL Strict"
    echo -e "  ${CYAN}[R]${NC} Reiniciar LAMP"

    echo -e "\n  ${BOLD}🐘 CAMBIAR VERSIÓN DE PHP${NC}"
    for i in "${!VERSIONES_PHP[@]}"; do
        printf "  ${CYAN}%2d)${NC} Cambiar a PHP %s\n" $((i+1)) "${VERSIONES_PHP[$i]}"
    done

    echo -e "\n  ${CYAN}[0]${NC} Salir del configurador"
    echo -e "  ${CYAN}——————————————————————————————————————————————————${NC}"
    echo -ne "  ${BOLD}Selecciona una opción:${NC} "
}

# --- Bucle Principal ---

while :
do
    _menu
    read -r opc

    case $opc in
        i|I) echo ""; _gestion_servicio "start" "apache2 mariadb" "Levantando servicios LAMP"; _pausa ;;
        p|P) echo ""; _gestion_servicio "stop" "apache2 mariadb" "Deteniendo servicios LAMP"; _pausa ;;
        r|R) echo ""; _gestion_servicio "restart" "apache2 mariadb" "Reiniciando servicios LAMP"; _pausa ;;

        a|A)
            echo ""
            if [ -f "$STRICT_MODE_BACKUP" ]; then
                (sudo cp "$STRICT_MODE_BACKUP" "$STRICT_MODE_FILE" && sudo systemctl restart mysql) &
                _progreso $! "Activando StrictMode"
            else
                echo -e "  ${RED}⚠ Error: Archivo backup no encontrado en $STRICT_MODE_BACKUP${NC}"
            fi
            _pausa ;;

        d|D)
            echo ""
            (sudo rm -f "$STRICT_MODE_FILE" && sudo systemctl restart mysql) &
            _progreso $! "Desactivando StrictMode"
            _pausa ;;

        [0-9]|[1-9][0-9])
            if [ "$opc" -eq 0 ]; then
                echo -e "\n  ${MAGENTA}👋 ¡Hasta luego!${NC}\n"
                exit 0
            fi

            idx=$((opc-1))
            if [ $idx -ge 0 ] && [ $idx -lt ${#VERSIONES_PHP[@]} ]; then
                echo ""
                _cambiar_php "${VERSIONES_PHP[$idx]}"
                _pausa
            else
                echo -e "\n  ${RED}⚠ Opción inválida${NC}" ; sleep 1
            fi
            ;;
        *)
            echo -e "\n  ${RED}⚠ Opción inválida${NC}" ; sleep 1 ;;
    esac
done
